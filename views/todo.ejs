<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Plans To-Do List</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Poppins", sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(
                135deg,
                #0f172a 0%,
                #1e293b 40%,
                #312e81 100%
            );
            color: white;
            padding: 40px 20px;
        }

        .container {
            max-width: 900px;
            margin: auto;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 12px;
            line-height: 1.3;
        }

        .header p {
            color: #cbd5e1;
            font-size: 1.05rem;
        }

        .todo-list {
            list-style: none;
            margin-bottom: 30px;
        }

        .todo-list li {
            position: relative;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 18px 80px 18px 20px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
            word-wrap: break-word;
        }

        .todo-list li:hover {
            transform: translateY(-3px);
            background: rgba(255, 255, 255, 0.12);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.25);
        }

        .todo-text {
            font-size: 1rem;
            color: #f8fafc;
        }

        .delete-btn,
        .edit-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            text-decoration: none;
            font-size: 1.2rem;
            transition: 0.3s ease;
        }

        .delete-btn {
            right: 18px;
            color: #ff5c7a;
        }

        .delete-btn:hover {
            transform: translateY(-50%) scale(1.2);
        }

        .edit-btn {
            right: 55px;
            color: #ffd166;
        }

        .edit-btn:hover {
            transform: translateY(-50%) scale(1.2);
        }

        .form-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            padding: 25px;
        }

        .form-card label {
            display: block;
            margin-bottom: 12px;
            font-weight: 500;
            color: #e2e8f0;
        }

        .form-card input[type="text"] {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            outline: none;
            background: rgba(255, 255, 255, 0.12);
            color: white;
            font-size: 1rem;
            margin-bottom: 15px;
        }

        .form-card input[type="text"]::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .form-card input[type="submit"] {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            color: white;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            transition: all 0.3s ease;
        }

        .form-card input[type="submit"]:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);
        }

        .empty-state {
            text-align: center;
            padding: 30px;
            color: #cbd5e1;
            background: rgba(255,255,255,0.05);
            border-radius: 16px;
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.8rem;
            }

            .header p {
                font-size: 0.95rem;
            }

            .todo-list li {
                padding-right: 75px;
            }
        }
    </style>
</head>

<body>
    <div class="container">

        <div class="header">
            <h1>
                🚀 Hello Everyone! This is your To-Do List
            </h1>

            <p>
                Write your plans on learning any technology you want to master.
                Share your learning goals and track your progress.
            </p>
        </div>

        <% if (todolist.length === 0) { %>
            <div class="empty-state">
                <h3>No learning plans added yet 📚</h3>
                <p>Add your first learning goal below.</p>
            </div>
        <% } %>

        <ul class="todo-list">
            <% todolist.forEach(function(todo, index) { %>
            <li>
                <a href="/todo/delete/<%= index %>" class="delete-btn" title="Delete">
                    ❌
                </a>

                <a href="/todo/<%= index %>" class="edit-btn" title="Edit">
                    ✏️
                </a>

                <div class="todo-text">
                    <%- todo %>
                </div>
            </li>
            <% }); %>
        </ul>

        <div class="form-card">
            <form action="/todo/add/" method="post">
                <label for="newtodo">
                    🎯 What technology do you want to learn?
                </label>

                <input
                    type="text"
                    name="newtodo"
                    id="newtodo"
                    placeholder="Example: Learn Jenkins, Docker, Kubernetes, AWS..."
                    autofocus
                    required
                >

                <input type="submit" value="Add Learning Plan">
            </form>
        </div>

    </div>
</body>
</html>